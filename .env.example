# ==============================================
# RAG Service - Environment Variables Example
# ==============================================
# Instructions:
# 1) Default configuration is located in: src/rag_service/core/settings.py
# 2) This file is used for centralized configuration management in production
# 3) If environment variables are not yet enabled, use as reference documentation

# ---------- Service Configuration ----------
RAG_SERVER_HOST=0.0.0.0
RAG_SERVER_PORT=8000
RAG_SERVER_CORS_ORIGINS=*

# ---------- Model Configuration ----------
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_RERANK_MODEL=BAAI/bge-reranker-base
RAG_MODEL_CACHE_FOLDER=./model_cache

# ---------- LLM Inference Service ----------
RAG_OLLAMA_URL=http://localhost:11434
RAG_OLLAMA_MODEL=deepseek-r1:7b
RAG_OLLAMA_TIMEOUT=60

# ---------- Retrieval Features ----------
RAG_ENABLE_DOC2QUERY=true
RAG_ENABLE_RERANK=true
RAG_ENABLE_QUERY_REWRITE=true

# ---------- Text Processing ----------
RAG_TEXT_CHUNK_SIZE=1024
RAG_TEXT_CHUNK_OVERLAP=200

# ---------- Search Parameters ----------
RAG_SEARCH_DEFAULT_TOP_K=5
RAG_SEARCH_MAX_TOP_K=15
RAG_DOC2QUERY_NUM_QUERIES=3

# ---------- Local Storage Paths ----------
RAG_FAISS_INDEX_FILE=vector_db/faiss_index.index
RAG_CHUNKS_FILE=cache/chunks/chunks.json
RAG_MD5_RECORD_FILE=records/md5_record.json
RAG_DOCUMENTS_FOLDER=documents